{
  "name": "trade-journal",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:smoke": "maestro test .maestro/flows/smoke-lane-c.yaml",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "verify:baseline": "npm run test:unit && npm run test:integration && npm run typecheck && npm run lint",
    "verify:lane:a": "node scripts/verify-lane.mjs A",
    "verify:lane:b": "node scripts/verify-lane.mjs B",
    "verify:lane:c": "node scripts/verify-lane.mjs C"
  },
